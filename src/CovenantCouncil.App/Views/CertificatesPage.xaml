<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CovenantCouncil.App.Views.CertificatesPage"
             Title="Certificates">
  <Grid Padding="20" RowDefinitions="Auto,*" RowSpacing="16">
    <HorizontalStackLayout Spacing="12">
      <Label Text="Certificates" FontSize="24" FontAttributes="Bold" VerticalOptions="Center" />
      <Button Text="Refresh" Clicked="RefreshClicked" />
    </HorizontalStackLayout>
    <CollectionView Grid.Row="1" ItemsSource="{Binding Roots}">
      <CollectionView.ItemTemplate>
        <DataTemplate>
          <Grid Padding="12" RowDefinitions="Auto,Auto" BackgroundColor="{StaticResource PanelBackground}" Margin="0,0,0,8">
            <Label Text="{Binding Certificate.Subject}" FontAttributes="Bold" />
            <Label Grid.Row="1" Text="{Binding Certificate.Thumbprint}" TextColor="{StaticResource TextSecondary}" />
          </Grid>
        </DataTemplate>
      </CollectionView.ItemTemplate>
    </CollectionView>
    <Grid Grid.RowSpan="2"
          BackgroundColor="#80000000"
          IsVisible="{Binding IsBusy}">
      <ActivityIndicator IsRunning="{Binding IsBusy}"
                         WidthRequest="48"
                         HeightRequest="48"
                         HorizontalOptions="Center"
                         VerticalOptions="Center" />
    </Grid>
  </Grid>
</ContentPage>
