<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CovenantCouncil.App.Views.PartiesPage"
             Title="Parties">
  <Grid Padding="20" RowDefinitions="Auto,*" RowSpacing="16">
    <HorizontalStackLayout Spacing="12">
      <Label Text="Parties" FontSize="24" FontAttributes="Bold" VerticalOptions="Center" />
      <Picker Title="Type" ItemsSource="{Binding KindFilters}" SelectedItem="{Binding SelectedKind}" WidthRequest="220" />
      <Button Text="Add" Clicked="AddClicked" />
      <Button Text="Refresh" Clicked="RefreshClicked" />
    </HorizontalStackLayout>
    <CollectionView Grid.Row="1" ItemsSource="{Binding Parties}">
      <CollectionView.ItemTemplate>
        <DataTemplate>
          <Grid Padding="12" ColumnDefinitions="160,*,220,Auto" BackgroundColor="{StaticResource PanelBackground}" Margin="0,0,0,8">
            <Label Text="{Binding Kind}" TextColor="{StaticResource Gold}" />
            <Label Grid.Column="1" Text="{Binding DisplayName}" FontAttributes="Bold" />
            <Label Grid.Column="2" Text="{Binding Email}" TextColor="{StaticResource TextSecondary}" />
            <Button Grid.Column="3" Text="Delete" CommandParameter="{Binding Id}" Clicked="DeleteClicked" />
          </Grid>
        </DataTemplate>
      </CollectionView.ItemTemplate>
    </CollectionView>
    <Grid Grid.RowSpan="2"
          BackgroundColor="#80000000"
          IsVisible="{Binding IsBusy}">
      <ActivityIndicator IsRunning="{Binding IsBusy}"
                         WidthRequest="48"
                         HeightRequest="48"
                         HorizontalOptions="Center"
                         VerticalOptions="Center" />
    </Grid>
  </Grid>
</ContentPage>
