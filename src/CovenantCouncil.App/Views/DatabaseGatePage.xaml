<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CovenantCouncil.App.Views.DatabaseGatePage"
             Title="Database">
  <Grid Padding="28" RowDefinitions="Auto,*" ColumnDefinitions="320,*" ColumnSpacing="28">
    <VerticalStackLayout Spacing="16">
      <Image Source="covenant_council_logo.svg" HeightRequest="120" WidthRequest="120" HorizontalOptions="Start" />
      <Label Text="Covenant Council" FontSize="28" FontAttributes="Bold" />
      <Label Text="Open or create a portable .ccdb database." TextColor="{StaticResource TextSecondary}" />
      <Button Text="Settings" Clicked="SettingsClicked" HorizontalOptions="Start" />
    </VerticalStackLayout>

    <Grid Grid.Column="1" RowDefinitions="Auto,Auto,Auto" RowSpacing="14">
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
        <Entry Placeholder="Database path (.ccdb)" Text="{Binding DatabasePath}" IsReadOnly="True" />
        <Button Grid.Column="1" Text="Pick File" Clicked="PickFileClicked" />
      </Grid>
      <Entry Grid.Row="1" Placeholder="Password" IsPassword="True" Text="{Binding Password}" />
      <HorizontalStackLayout Grid.Row="2" Spacing="10">
        <Button x:Name="OpenOrCreateButton" Text="Open or Create" Clicked="OpenOrCreateClicked" />
      </HorizontalStackLayout>
    </Grid>
    <Grid Grid.RowSpan="2" Grid.ColumnSpan="2"
          BackgroundColor="#80000000"
          IsVisible="{Binding IsBusy}">
      <ActivityIndicator IsRunning="{Binding IsBusy}"
                         WidthRequest="48"
                         HeightRequest="48"
                         HorizontalOptions="Center"
                         VerticalOptions="Center" />
    </Grid>
  </Grid>
</ContentPage>
